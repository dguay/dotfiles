# Shortcuts
alias la="ls -laF"
alias -g G="| grep"
alias h="history"
alias ..="cd .."
alias ~="cd ~"
alias q="~ && clear"
alias clr="clear"

alias reloadcli="source $HOME/.zshrc"

# Git
alias glod="git pull origin develop"
alias gs='git status'
alias gp='git push'
alias gl='git pull'
alias gco='git checkout'
alias gd='git diff'

# Directories
alias dotfiles="cd $DOTFILES"

# Config files
alias zshconfig="vim ~/.dotfiles/zshrc"

# Meteo
alias meteo="curl wttr.in/quebec"

# Functions

function findstring() {
  grep -rnw $2 -e $1
}

function findname() {
  find $2 -name $1 -print
}
